<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 🔷 HEADER -->
        <LinearLayout
            android:background="@color/primary"
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="MedBridge"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Offline Medical Triage System"
                android:textColor="#D0E6F6"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- 🔽 CONTENT -->
        <LinearLayout
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- SECTION: PATIENT INFO -->
            <TextView
                android:text="Patient Information"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#EFEDED"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:padding="16dp"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/nameInput"
                        android:hint="Patient Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/ageInput"
                        android:hint="Age"
                        android:inputType="number"
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/genderLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp"
                        android:hint="@string/Select_Gender"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/genderDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- SECTION: CONDITION -->
            <TextView
                android:text="Clinical Condition"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#EFEDED"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:padding="16dp"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Bleeding Level"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <RadioGroup
                        android:id="@+id/bleedingGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/bleedingNone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None"
                            android:checked="true"/>

                        <RadioButton
                            android:id="@+id/bleedingMild"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mild"/>

                        <RadioButton
                            android:id="@+id/bleedingSevere"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Severe"/>
                    </RadioGroup>

                    <Switch
                        android:id="@+id/consciousSwitch"
                        android:text="Patient is conscious"
                        android:layout_marginTop="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <CheckBox
                        android:id="@+id/fractureCheck"
                        android:text="Fracture present"
                        android:layout_marginTop="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/fractureLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp"
                        android:hint="@string/Select_Gender"
                        android:visibility="gone"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/fractureDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <CheckBox
                        android:id="@+id/CurrentDisease"
                        android:text="Any Current Disease"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:visibility="gone"
                        android:id="@+id/CurrentDiseaseInput"
                        android:hint="Disease Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <CheckBox
                        android:id="@+id/PreviousDisease"
                        android:text="Any Previous Disease"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:visibility="gone"
                        android:id="@+id/PreviousDiseaseInput"
                        android:hint="Disease Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>


                </LinearLayout>

            </androidx.cardview.widget.CardView>



            <!-- SECTION: MEDICATION -->
            <TextView
                android:text="Medications"
                android:layout_marginBottom="5dp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#EFEDED"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:padding="16dp"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/medInput"
                        android:hint="e.g. Aspirin, Ibuprofen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- CTA BUTTON -->
            <Button
                android:id="@+id/analyzeBtn"
                android:text="Run Triage Analysis"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="@color/primary"
                android:layout_marginTop="24dp"
                android:layout_width="match_parent"
                android:layout_height="60dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>