<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F4F7FB"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 🔷 HEADER -->
        <LinearLayout
            android:background="@color/primary"
            android:padding="24dp"
            android:elevation="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="50dp">
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/logo"
                        />

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_marginStart="15dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:text="MedBridge"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Offline Emergency Triage System"
                        android:textColor="#E3F2FD"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </LinearLayout>

            <Button
                android:id="@+id/radioBtn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:text="📡"
                android:textSize="18sp"
                android:layout_marginStart="10dp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#192841"/>

            <TextView
                android:id="@+id/radioStatus"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginTop="12dp"
                android:text="Radio Status: Idle"
               />

        </LinearLayout>

        <!-- CONTENT -->
        <LinearLayout
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 🧑‍⚕️ PATIENT INFO -->
            <TextView
                android:text="Patient Information"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <androidx.cardview.widget.CardView
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/nameInput"
                        android:hint="Patient Name"
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/ageInput"
                        android:hint="Age"
                        android:inputType="number"
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/genderLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="Select Gender"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/genderDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 🩺 CONDITION -->
            <TextView
                android:text="Clinical Condition"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

            <androidx.cardview.widget.CardView
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Bleeding -->
                    <TextView
                        android:text="Bleeding Level"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <RadioGroup
                        android:id="@+id/bleedingGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <RadioButton
                            android:id="@+id/bleedingNone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None"
                            android:checked="true"/>

                        <RadioButton
                            android:id="@+id/bleedingMild"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mild"
                            android:layout_marginStart="12dp"/>

                        <RadioButton
                            android:id="@+id/bleedingSevere"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Severe"
                            android:layout_marginStart="12dp"/>
                    </RadioGroup>

                    <!-- Conscious -->
                    <Switch
                        android:id="@+id/consciousSwitch"
                        android:text="Patient is conscious"
                        android:layout_marginTop="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <!-- Fracture -->
                    <CheckBox
                        android:id="@+id/fractureCheck"
                        android:text="Fracture present"
                        android:layout_marginTop="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/fractureLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Select Fracture"
                        android:visibility="gone"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/fractureDropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Diseases -->

                    <CheckBox
                        android:id="@+id/CurrentDisease"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Disease" />

                    <EditText
                        android:id="@+id/CurrentDiseaseInput"
                        android:visibility="gone"
                        android:hint="Disease Name"
                        android:background="@drawable/input_bg"
                        android:padding="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <CheckBox
                        android:id="@+id/PreviousDisease"
                        android:text="Previous Disease"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/PreviousDiseaseInput"
                        android:visibility="gone"
                        android:hint="Disease Name"
                        android:background="@drawable/input_bg"
                        android:padding="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 💊 MEDICATION -->
            <TextView
                android:text="Medications"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.cardview.widget.CardView
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/medInput"
                        android:hint="e.g. Aspirin, Ibuprofen"
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:text="View Radio Logs"
                android:onClick="openLogs"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary"/>

            <!-- 🚀 BUTTON -->
            <Button
                android:id="@+id/analyzeBtn"
                android:text="Run Triage Analysis"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"
                android:backgroundTint="@color/primary"
                android:layout_marginTop="15dp"
                android:elevation="8dp"
                android:layout_width="match_parent"
                android:layout_height="60dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>